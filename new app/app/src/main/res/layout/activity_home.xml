<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/linear2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/colorPrimary"
        android:padding="16dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/circleimageview1"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_launcher" />

        <TextView
            android:id="@+id/textview1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginLeft="12dp"
            android:text="YouTube Watch Time"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Input Section -->
    <LinearLayout
        android:id="@+id/linear3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <EditText
            android:id="@+id/edittext2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Enter Video URL"
            android:inputType="textUri"
            android:padding="12dp"
            android:background="@drawable/edittext_border" />

        <ImageView
            android:id="@+id/imageview1"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginLeft="8dp"
            android:src="@drawable/ic_play"
            android:contentDescription="Play Video"
            android:background="@color/colorPrimary"
            android:padding="8dp" />
    </LinearLayout>

    <!-- WebView Preview -->
    <WebView
        android:id="@+id/webview1"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:visibility="gone" />

    <!-- Video Buttons Grid -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/linear4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- Row 1: 5 Videos -->
            <LinearLayout
                android:id="@+id/linear5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/button1"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="5 Videos"
                    android:padding="12dp"
                    android:layout_margin="4dp"
                    android:backgroundTint="@color/colorPrimary" />

                <Button
                    android:id="@+id/button2"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="10 Videos"
                    android:padding="12dp"
                    android:layout_margin="4dp"
                    android:backgroundTint="@color/colorPrimary" />

                <Button
                    android:id="@+id/button3"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="15 Videos"
                    android:padding="12dp"
                    android:layout_margin="4dp"
                    android:backgroundTint="@color/colorPrimary" />

                <Button
                    android:id="@+id/button4"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="20 Videos"
                    android:padding="12dp"
                    android:layout_margin="4dp"
                    android:backgroundTint="@color/colorPrimary" />

                <Button
                    android:id="@+id/button5"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="25 Videos"
                    android:padding="12dp"
                    android:layout_margin="4dp"
                    android:backgroundTint="@color/colorPrimary" />
            </LinearLayout>

            <Button
                android:id="@+id/button6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="500 Views (Preview)"
                android:padding="12dp"
                android:layout_margin="4dp"
                android:backgroundTint="@color/colorPrimary" />

            <!-- Extra Buttons -->
            <LinearLayout
                android:id="@+id/linear6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/button8"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="WhatsApp Channel"
                    android:padding="12dp"
                    android:layout_margin="4dp"
                    android:backgroundTint="#25D366" />

                <Button
                    android:id="@+id/button7"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="More Apps"
                    android:padding="12dp"
                    android:layout_margin="4dp"
                    android:backgroundTint="#FF6D00" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>